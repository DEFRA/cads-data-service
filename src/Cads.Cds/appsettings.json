{
  "AWS": {
    "Region": "eu-west-2",
    "EMF": {
      "Namespace": "cads-data-service",
      "ServiceName": "Cads.Cds"
    },
    "Metrics": {
      "MeterName": "CadsCds"
    }
  },
  "Postgres": {
    "DefaultConnection": "Replace in docker-compose.override.yml",
    "ReadOnlyConnection": "Replace in docker-compose.override.yml",
    "UseIamAuthentication": false,
    "DefaultHost": "Replace in cdp-app-config",
    "ReadOnlyHost": "Replace in cdp-app-config",
    "Port": 5432,
    "Name": "Replace in cdp-app-config",
    "User": "Replace in cdp-app-config"
  },
  "AllowedHosts": "*",
  "TraceHeader": "x-cdp-request-id",
  "HealthcheckMaskingEnabled": false,
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "service.name": "cads-data-service",
      "environment": "%ASPNETCORE_ENVIRONMENT%"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Elastic.CommonSchema.Serilog.EcsTextFormatter, Elastic.CommonSchema.Serilog"
        }
      }
    ]
  },
  "AuthenticationConfiguration": {
    "ApiKey": {
      "Enabled": false
    },
    "Cognito": {
      "Enabled": false,
      "Authority": null
    },
    "AzureAD": {
      "Enabled": false,
      "Authority": null,
      "Audience": null
    }
  },
  "Acl": {
    "Clients": {
      "ApiKey": {
        "Type": "ApiKey",
        "Secret": "Set in cdp-app-config (or for local development using docker-compose.override.yml)",
        "Scopes": [ "access" ]
      }
    }
  },
  "Modules": {
    "Api": {},
    "Ingester": {
      "Queues": {
        "CadsCds": {
          "Name": "CadsCdsQueueClient",
          "QueueUrl": "Set in cdp-app-config (or for local development using docker-compose.override.yml)",
          "DlqQueueUrl": "Set in cdp-app-config (or for local development using docker-compose.override.yml)",
          "MaxNumberOfMessages": 10,
          "WaitTimeSeconds": 5,
          "HealthcheckEnabled": true
        }
      }
    },
    "MiBff": {
      "StaticData": {
        "Enabled": true,
        "Path": "StaticData"
      }
    },
    "StorageBridge": {
      "Storage": {
        "CadsInternal": {
          "BucketName": "Set in cdp-app-config (or for local development using docker-compose.override.yml)",
          "HealthcheckEnabled": true
        }
      }
    }
  }
}
