{
  "DetailedErrors": true,
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:o} [{Level:u4}] ({Application}/{MachineName}/{ThreadId}/{SourceContext}.{Method}) {Message}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AuthenticationConfiguration": {
    "ApiKey": {
      "Enabled": true
    },
    "Cognito": {
      "Enabled": true,
      "Authority": "https://cognito-test"
    },
    "AzureAD": {
      "Enabled": true,
      "Authority": "http://localhost:5557",
      "Audience": "api://local-cads-cds",
      "MetadataAddress": "http://localhost:5557/.well-known/openid-configuration",
      "RequireHttpsMetadata": false,
      "ValidateIssuer": false,
      "RoleClaimType": "scope"
    }
  },
  "Acl": {
    "Clients": {
      "ApiKey": {
        "Type": "ApiKey",
        "Secret": "integration-test-secret",
        "Scopes": [ "access", "reports.read" ]
      }
    }
  }
}
